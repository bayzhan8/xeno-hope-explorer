# Copy to .env and fill in. All VITE_ vars are inlined into the public client
# bundle at build time, so do NOT put real secrets here.

# Base URL of the public Supabase Storage bucket that holds the viz JSONs.
# (Public read endpoint, no API key.) Get the value from a maintainer.
VITE_SUPABASE_STORAGE_URL=https://<project-ref>.supabase.co/storage/v1/object/public/viz-data

# Expose the /bridge route. Anything other than the literal "false" enables it.
VITE_FEATURE_BRIDGE=true
